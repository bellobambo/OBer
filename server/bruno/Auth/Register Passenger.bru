meta {
  name: Register Passenger
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "role": "PASSENGER",
    "phone": "08012345678",
    "email": "passenger@example.com",
    "password": "password123"
  }
}
